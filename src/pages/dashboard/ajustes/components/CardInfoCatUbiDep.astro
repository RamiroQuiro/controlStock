---
import { Tag, Edit, Trash2, CircleX } from 'lucide-react';
import Button from '../../../../components/atomos/Button.astro';
import Card from '../../../../components/organismos/Card.astro';
import Texto from '../../../../components/atomos/Texto';
import FormularioNuevaCategoria from './FormularioNuevaCat';
import formatDate from '../../../../utils/formatDate';
import BotonDeleteCategoria from './BotonDeleteCategoria.astro';
import BotonDesactivarCat from './BotonDesactivarCat';

interface Item {
  id: string;
  nombre: string;
  descripcion: string;
  color?: string;
  activo: boolean;
  creadoPor: string;
  created_at: string;
  cantidadProductos: number;
}

const { item, type } = Astro.props as {
  item: Item;
  type: 'categoria' | 'ubicacion' | 'deposito';
};

const formProps = {
  [type]: item,
};
---

<Card
  styleDiv={`hover:shadow-lg duration-300 transition-all gap-4 cursor-pointer ${
    item.activo ? '' : 'opacity-75'
  }`}
>
  <div class="flex p-4 flex-col w-full gap-4">
    <div class="flex flex-col gap-y-2 items-start w-full justify-between">
      <div class="flex items-center w-full justify-between">
        <div class="flex items-center gap-x-2 w-full">
          {
            type === 'categoria' && (
              <div
                class={`p-2 rounded-lg ${item.color || 'bg-blue-500'} text-white`}
              >
                <Tag className="w-4 h-4 group-hover:scale-110 duration-300" />
              </div>
            )
          }
          <div>
            <Texto as="h3" variant="h2" className="capitalize">
              {item.nombre}
            </Texto>
          </div>
        </div>
        <span
          class={`text-xs lowercase px-2 rounded-lg py-1 text-primary-textoTitle font-semibold ${item.activo ? 'bg-green-500/50' : 'bg-red-600/40'}`}
        >
          {item.activo ? 'activo' : 'inactivo'}
        </span>
      </div>
    </div>
    <div class="flex flex-col gap-2 items-start w-full justify-between">
      <span class="text-sm mb-4">{item.descripcion}</span>

      <div class="flex items-center w-full justify-between">
        <div class="text-lg font-semibold text-gray-700">
          {item.cantidadProductos}
          {item.cantidadProductos === 1 ? 'producto' : 'productos'}
        </div>
        <span class="text-sm text-gray-500">
          Creada: {formatDate(item.created_at)}
        </span>
      </div>
    </div>
    <div class="flex gap-2">
      <Button variant="outline" id={`editar-${type}-${item.id}`}>
        <Edit className="h-4 w-4" />
      </Button>
      <BotonDesactivarCat item={item} client:load />
      <BotonDeleteCategoria item={item} type={type} />
    </div>
  </div>

  <dialog
    id={`dialog-editar-${type}-${item.id}`}
    class="modal print:hidden relative duration-300 open:fixed open:flex flex-col rounded-lg border-l-2 border-primary-100 backdrop:bg-primary-textoTitle/80 open:backdrop:backdrop-blur-sm"
  >
    <form method="dialog">
      <button
        id={`cerrarModal-editar-${type}-${item.id}`}
        class="absolute top-2 right-2 cursor-pointer text-primary-texto active:-scale-95 duration-200 hover:text-primary-100"
      >
        <CircleX />
      </button>
    </form>
    <FormularioNuevaCategoria category={item} client:load />
  </dialog>
</Card>
<script define:vars={{ item, type }}>
  const btnEditar = document.getElementById(`editar-${type}-${item.id}`);
  btnEditar?.addEventListener('click', () => {
    const dialog = document.getElementById(`dialog-editar-${type}-${item.id}`);
    dialog.showModal();
  });
</script>
