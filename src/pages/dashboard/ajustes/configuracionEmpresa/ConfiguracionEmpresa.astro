---
import { Building2 } from "lucide-react";
import MainDashboard from "../../../../components/atomos/MainDashboard.astro";
import FormularioEmpresa from "./components/FormularioEmpresa.jsx";
import Card from "../../../../components/organismos/Card.astro";

const { user } = Astro.locals;
---

<MainDashboard
  h1="Configuración de la Empresa"
  subtitle="Actualiza los datos y el logo de tu empresa."
  icon={Building2}
>
  <Card styleDiv="w-fit">
    <FormularioEmpresa client:load user={user} />
  </Card>
</MainDashboard>
