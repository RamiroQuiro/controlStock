---
import MainDashboard from "../../../../components/atomos/MainDashboard.astro";
import ContenedorFormulario from "./ContenedorFormulario.astro";
import FormularioCambiarPassword from "../components/FormularioCambiarPassword";
import { User2 } from "lucide-react";
import Card from "../../../../components/organismos/Card.astro";

const { user } = Astro.locals;
---

<MainDashboard
  h1="Perfil de Usuario"
  subtitle="Administra tu información personal y preferencias de cuenta."
  icon={User2}
>
  <div
    class="flex w-full md:flex-row flex-col items-stretch gap-2 justify-between"
  >
    <Card styleDiv="md:w-2/3 w-full">
      <ContenedorFormulario />
    </Card>
    <Card styleDiv="md:w-1/3 w-full h-full">
      <FormularioCambiarPassword client:load user={user} />
    </Card>
  </div>
</MainDashboard>
