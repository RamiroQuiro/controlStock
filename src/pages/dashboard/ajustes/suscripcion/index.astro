---
import LayoutDash from "../../../../components/layouts/LayoutDash.astro";
import MainDashboard from "../../../../components/atomos/MainDashboard.astro";
import Card from "../../../../components/organismos/Card.astro";
import Texto from "../../../../components/atomos/Texto";
import Button from "../../../../components/atomos/Button.astro";
import db from "../../../../db";
import { empresas, planes } from "../../../../db/schema";
import { eq } from "drizzle-orm";
import { Users, Store, Package, Rocket, CheckCircle2 } from "lucide-react";

const { user } = Astro.locals;
const empresaId = user?.empresaId;

if (!empresaId) return Astro.redirect("/dashboard");

// Obtener datos de la empresa y su plan
const [empresaData] = await db
  .select({
    empresa: empresas,
    plan: planes,
  })
  .from(empresas)
  .leftJoin(planes, eq(empresas.planId, planes.id))
  .where(eq(empresas.id, empresaId));

const planActual = empresaData?.plan;
const infoEmpresa = empresaData?.empresa;

// Obtener todos los planes para la comparativa
const todosLosPlanes = await db
  .select()
  .from(planes)
  .orderBy(planes.precioMensual);

const stats = [
  {
    label: "Usuarios",
    actual: infoEmpresa?.cantidadUsuarios || 0,
    limite: planActual?.limiteUsuarios || 0,
    icon: Users,
    color: "bg-blue-500",
  },
  {
    label: "Sucursales",
    actual: infoEmpresa?.cantidadSucursales || 0,
    limite: planActual?.limiteSucursales || 0,
    icon: Store,
    color: "bg-purple-500",
  },
  {
    label: "Productos",
    actual: infoEmpresa?.cantidadProductos || 0,
    limite: planActual?.limiteProductos || 0,
    icon: Package,
    color: "bg-orange-500",
  },
];

function calculatePercentage(actual: number, limite: number) {
  if (limite === -1) return 0; // Ilimitado
  if (limite === 0) return 100;
  return Math.min(Math.round((actual / limite) * 100), 100);
}
---

<LayoutDash title="Mi Suscripción">
  <MainDashboard
    h1="Mi Suscripción"
    subtitle="Gestiona tu plan y límites de uso"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      {
        stats.map((stat) => {
          const porc = calculatePercentage(stat.actual, stat.limite);
          const isIlimitado = stat.limite === -1;

          return (
            <Card>
              <div class="flex items-center justify-between mb-4">
                <div class="p-3 rounded-xl bg-gray-50 text-gray-700">
                  <stat.icon className="w-6 h-6" />
                </div>
                <span class="text-sm font-medium text-gray-500">
                  {isIlimitado ? "Sin límite" : `${porc}% en uso`}
                </span>
              </div>

              <Texto as="h3" variant="title" className="mb-1">{stat.label}</Texto>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-2xl font-bold text-primary-100">
                  {stat.actual}
                </span>
                <span class="text-gray-400">
                  / {isIlimitado ? "∞" : stat.limite}
                </span>
              </div>

              {!isIlimitado && (
                <div class="w-full bg-gray-100 rounded-full h-2">
                  <div
                    class={`h-2 rounded-full ${porc > 90 ? "bg-red-500" : stat.color}`}
                    style={`width: ${porc}%`}
                  />
                </div>
              )}
            </Card>
          );
        })
      }
    </div>

    <div
      class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm mb-12"
    >
      <div
        class="flex flex-col md:flex-row md:items-center justify-between gap-6"
      >
        <div>
          <div class="flex items-center gap-3 mb-2">
            <Rocket className="w-8 h-8 text-primary-100" />
            <Texto as="h2" variant="h2">
              Plan Actual: <span class="text-primary-100"
                >{planActual?.nombre}</span>
            </Texto>
          </div>
          <p class="text-gray-500 max-w-2xl">{planActual?.descripcion}</p>
        </div>
        <div class="text-right">
          <p class="text-3xl font-bold text-gray-800">
            ${planActual?.precioMensual.toLocaleString()}<span
              class="text-lg font-normal text-gray-400">/mes</span>
          </p>
          <p class="text-sm text-gray-400">
            Próximo vencimiento: {
              infoEmpresa?.fechaVencimiento?.toLocaleDateString() || "N/A"
            }
          </p>
        </div>
      </div>
    </div>

    <Texto as="h2" variant="h2" className="mb-8 flex items-center gap-3">
      <CheckCircle2 className="w-7 h-7 text-green-500" />
      Planes Disponibles
    </Texto>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {
        todosLosPlanes.map((plan) => (
          <div
            class={`p-6 rounded-3xl border ${plan.id === planActual?.id ? "border-primary-100 bg-primary-50/10" : "border-gray-100 bg-white"} flex flex-col h-full transition-all hover:shadow-lg`}
          >
            {plan.id === planActual?.id && (
              <span class="bg-primary-100 text-white text-xs font-bold px-3 py-1 rounded-full w-max mb-4">
                PLAN ACTUAL
              </span>
            )}
            <Texto as="h3" variant="title" className="mb-1">{plan.nombre}</Texto>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-2xl font-bold text-gray-800">
                ${plan.precioMensual.toLocaleString()}
              </span>
              <span class="text-gray-400 text-sm">/mes</span>
            </div>

            <ul class="space-y-3 mb-8 flex-grow">
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <CheckCircle2 className="w-4 h-4 text-green-500" />
                {plan.limiteUsuarios} Usuarios
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <CheckCircle2 className="w-4 h-4 text-green-500" />
                {plan.limiteSucursales} Sucursales
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <CheckCircle2 className="w-4 h-4 text-green-500" />
                {plan.limiteProductos === -1
                  ? "Sin límite"
                  : `${plan.limiteProductos} Productos`}
              </li>
            </ul>

            <Button
              variant={plan.id === planActual?.id ? "grisClaro" : "primary"}
              className="w-full"
              disabled={plan.id === planActual?.id}
            >
              {plan.id === planActual?.id ? "Actual" : "Elegir Plan"}
            </Button>
          </div>
        ))
      }
    </div>
  </MainDashboard>
</LayoutDash>
