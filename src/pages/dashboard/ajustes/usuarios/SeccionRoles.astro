---
import { ShieldCheck } from "lucide-react";
import Card from "../../../../components/organismos/Card.astro";
import Texto from "../../../../components/atomos/Texto";
import ContenedorRoles from "../components/ContenedorRoles";

const { roles } = Astro.props;
---

<Card styleDiv="w-2/3">
  <div class="flex justify-between items-center mb-4">
    <div class="flex items-center">
      <ShieldCheck className="w-8 h-8 text-primary-100 mr-3" />
      <Texto as="h2" variant="h2">
        Roles y Permisos
      </Texto>
    </div>
  </div>

  <ContenedorRoles client:load roles={roles} />
</Card>
