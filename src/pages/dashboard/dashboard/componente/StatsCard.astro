---
import Card from "../../../../components/organismos/Card.astro";
import type { LucideIcon } from 'lucide-react';

interface StatsCardProps {
  title: string;
  value: string | number;
  icon: LucideIcon;
  subtitle?: string;
  trend?: {
    value: number;
    isPositive: boolean;
  };
  color?: string;
  index?: number;
}
const { title, value, icon: Icon, subtitle, trend, color = '#5FA5FA', index } = Astro.props as StatsCardProps;
---

<Card styleDiv="w-full md:h-28">
  <div class="flex w-full items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-600">{title}</p>
      <h3 class="mt-1 text-2xl font-semibold">{value}</h3>
      {subtitle && <p class="text-sm font-medium text-gray-600">{subtitle}</p>}
    </div>
    <div class={`rounded-full bg-primary-150 p-2`}>
      <Icon className="w-5" />
    </div>
  </div>
  <div class="mt-4"></div>
</Card>
