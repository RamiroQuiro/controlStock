---
import Card from "../../../../components/organismos/Card.astro";
import Texto from "../../../../components/atomos/Texto";

import ConfeccionListadoProductos from "./ConfeccionListadoProductos";
const { user } = Astro.locals;
---

<Card styleDiv="md:w-2/3 w-full">
  <div class="flex items-center justify-between gap-2">
    <Texto as="h2" variant="h2">Productos</Texto>
  </div>
  <!-- <FiltroProductos client:load empresaId={user?.empresaId}/> -->
  <div
    class="flex flex-col items-start justify-start gap-2 bg-primary-bg-componentes w-full md:p-2 p"
  >
    <ConfeccionListadoProductos empresaId={user?.empresaId} client:load />
  </div>
</Card>
